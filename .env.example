# Database
DATABASE_URL="postgresql://user:password@localhost:5432/dale_voz"

# Meta WhatsApp
META_BUSINESS_ACCOUNT_ID=your_business_account_id
META_WHATSAPP_PHONE_ID_CONVERSATIONS=your_phone_id_conversations
META_WHATSAPP_PHONE_ID_NOTIFICATIONS=your_phone_id_notifications
META_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# OpenAI / Grok
OPENAI_API_KEY=sk_...
XAI_API_KEY=xai_...

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=APP_USR_...
MERCADO_PAGO_PUBLIC_KEY=APP_USR_...

# Resend (Email)
RESEND_API_KEY=re_...

# Telnyx (fallback telephony)
TELNYX_API_KEY=key_...
TELNYX_DID_PE=+51...

# Server
PORT=3000
NODE_ENV=development

# nova-core service (external)
NOVA_CORE_URL=http://localhost:3001

# LiveKit (optional, for future Palier 2)
LIVEKIT_URL=ws://...
LIVEKIT_API_KEY=...
LIVEKIT_API_SECRET=...
